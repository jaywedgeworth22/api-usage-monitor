generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Provider {
  id                 String                      @id @default(uuid())
  name               String
  displayName        String
  type               String                      @default("builtin")
  category           String?
  apiKey             String?
  config             Json?
  isActive           Boolean                     @default(true)
  credits            Float                       @default(0)
  refreshIntervalMin Int                         @default(60)
  groupId            String?
  label              String?
  createdAt          DateTime                    @default(now())
  plan               ProviderPlan?
  snapshots          UsageSnapshot[]
  snapshotRollups    UsageSnapshotDailyRollup[]
  alertNotifications ProviderAlertNotification[]
  allocations        ProviderProjectAllocation[]
  subscriptions      Subscription[]
}

model ProviderPlan {
  id                  String    @id @default(uuid())
  providerId          String    @unique
  provider            Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  billingMode         String    @default("manual")
  fixedMonthlyCostUsd Float?
  monthlyBudgetUsd    Float?
  monthlyRequestLimit Int?
  lowBalanceUsd       Float?
  lowCredits          Float?
  renewalDate         DateTime?
  // Cadence at which renewalDate rolls forward once it passes (see
  // provider-alerts.ts effectiveRenewal + subscription-materializer's
  // renewal roll-forward). Independent of any Subscription row.
  billingInterval     String?   @default("monthly")
  mustKeepFunded      Boolean   @default(false)
  notes               String?
  // Machine-readable map of env-var knob name -> string value implied by this
  // provider's FREE tier (e.g. PROVIDER_QUOTA_* / PROVIDER_RATE_LIMIT_* / other
  // toggles a consuming app — Socratic.Trade — should apply at baseline). This
  // is the free-tier floor; a Subscription.knobEnv (paid tier) overrides it
  // when present. Null when no knob map has been defined yet.
  knobEnv             Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model UsageSnapshot {
  id            String   @id @default(uuid())
  providerId    String
  provider      Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  fetchedAt     DateTime
  balance       Float?
  totalCost     Float?
  totalRequests Int?
  credits       Float?
  rawData       Json?
  createdAt     DateTime @default(now())
}

model UsageSnapshotDailyRollup {
  id                  String   @id @default(uuid())
  providerId          String
  provider            Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  day                 DateTime
  sampleCount         Int      @default(0)
  firstFetchedAt      DateTime
  lastFetchedAt       DateTime
  latestBalance       Float?
  latestTotalCost     Float?
  latestTotalRequests Int?
  latestCredits       Float?
  minBalance          Float?
  maxBalance          Float?
  maxTotalCost        Float?
  maxTotalRequests    Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([providerId, day])
  @@index([day])
}

model ExternalUsageEvent {
  id             String    @id @default(uuid())
  // Prisma's client-side @default(uuid()) generates the value in the app process
  // before the INSERT is sent, so it works the same way on SQLite as it does on
  // any other datasource - no database-side function (e.g. Postgres's
  // gen_random_uuid()/pgcrypto) is required. In practice this default is a
  // safety net that's essentially never exercised: the app always supplies an
  // explicit, content-derived idempotencyKey on insert (see
  // usage-telemetry.ts's deriveIdempotencyKey).
  idempotencyKey String    @unique @default(uuid())
  sourceApp      String
  environment    String?
  provider       String
  service        String?
  label          String?
  keyRef         String?
  billingMode    String    @default("estimated")
  metricType     String    @default("usage")
  quantity       Float?
  unit           String?
  costUsd        Float?
  requests       Int?
  credits        Float?
  limit          Float?
  limitWindow    String?
  tier           String?
  confidence     String    @default("estimated")
  windowStart    DateTime?
  windowEnd      DateTime?
  occurredAt     DateTime
  metadata       Json?
  createdAt      DateTime  @default(now())
  // First-class per-project attribution. Resolved at ingest from a
  // producer-supplied project name (OTEL_RESOURCE_ATTRIBUTES `project` for
  // Claude Code, or the top-level `project` field on the generic ingest
  // contract) by matching Project.name case-insensitively. Null when no
  // project was supplied or none matched; the raw producer string is kept in
  // metadata so a Project created later can be back-filled. SetNull so
  // deleting a Project never destroys usage history.
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([sourceApp, occurredAt])
  @@index([provider, occurredAt])
  @@index([keyRef, occurredAt])
  @@index([projectId, occurredAt])
}

model ExternalUsageEventDailyRollup {
  id               String   @id @default(uuid())
  day              DateTime
  groupKey         String
  sourceApp        String
  environment      String?
  provider         String
  service          String?
  label            String?
  keyRef           String?
  billingMode      String
  metricType       String
  unit             String?
  limitWindow      String?
  tier             String?
  confidence       String
  // Denormalized project dimension so per-project cost survives the raw-event
  // retention cutoff. Folded into groupKey (see data-retention.ts's
  // externalGroupKey) so rollup buckets never merge across projects.
  projectId        String?
  eventCount       Int      @default(0)
  totalCostUsd     Float    @default(0)
  totalRequests    Int      @default(0)
  totalQuantity    Float    @default(0)
  totalCredits     Float    @default(0)
  maxLimit         Float?
  latestOccurredAt DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([day, groupKey])
  @@index([sourceApp, day])
  @@index([provider, day])
  @@index([projectId, day])
}

model ExternalUsageEventTombstone {
  idempotencyKey String   @id
  occurredAt     DateTime
  prunedAt       DateTime @default(now())

  @@index([occurredAt])
  @@index([prunedAt])
}

model ProviderAlertNotification {
  id                  String    @id @default(uuid())
  providerId          String
  provider            Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  stateKey            String    @unique
  alertCode           String
  severity            String
  providerName        String
  providerDisplayName String
  message             String
  firstDetectedAt     DateTime
  lastDetectedAt      DateTime
  lastSentAt          DateTime?
  sendCount           Int       @default(0)
  resolvedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([providerId, resolvedAt])
  @@index([lastSentAt])
}

model Project {
  id               String   @id @default(uuid())
  name             String   @unique
  // Lowercased/trimmed `name`, set on every create/rename. DB-enforced
  // case-insensitive uniqueness: since project attribution resolves
  // producer-supplied names case-insensitively (project-resolver.ts), two
  // projects differing only in case would make that ambiguous. `name` alone is
  // only BINARY-unique in SQLite, so this closes the concurrent-create race an
  // app-level check can't. Nullable so the column is an additive migration on
  // existing rows (they read back via the lowercased-name fallback).
  nameKey          String?  @unique
  description      String?
  monthlyBudgetUsd Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  allocations    ProviderProjectAllocation[]
  externalEvents ExternalUsageEvent[]
  subscriptions  Subscription[]
}

// Recurring, fixed-fee cost (a SaaS plan, seat, add-on, etc.) attached to a
// provider and optionally attributed to a project. Source of truth for the
// schedule; the actual money flows through the usage pipeline via the
// subscription materializer (src/lib/subscription-materializer.ts), which
// emits one synthetic ExternalUsageEvent (metricType="subscription") per
// elapsed billing period. That keeps subscription cost in the SAME
// month-to-date sums, rollups, per-project attribution, and budgets as
// metered usage — no special-casing in budget-status.
model Subscription {
  id                     String    @id @default(uuid())
  providerId             String
  provider               Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  // Optional project attribution: materialized charges carry this projectId so
  // the fee lands in the right project budget. SetNull so deleting a Project
  // doesn't cascade-delete the subscription.
  projectId              String?
  project                Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name                   String
  description            String?
  costUsd                Float
  currency               String    @default("USD")
  // weekly | monthly | quarterly | annual — combined with intervalCount for
  // arbitrary cadences (e.g. intervalCount=3 + interval="monthly").
  interval               String    @default("monthly")
  intervalCount          Int       @default(1)
  // Day-of-month the cycle renews (1-31); null derives the anchor from startDate.
  anchorDay              Int?
  startDate              DateTime
  currentPeriodStart     DateTime
  nextRenewalAt          DateTime
  // Materializer watermark: the periodStart of the most recent period already
  // emitted as a synthetic charge. Null until the first charge is generated.
  lastChargedPeriodStart DateTime?
  autoRenew              Boolean   @default(true)
  // active | paused | canceled | considering — only "active" subscriptions
  // generate charges. "considering" models a candidate paid tier that isn't
  // purchased yet, so its knobEnv can be compared against the free tier
  // without emitting phantom spend.
  status                 String    @default("active")
  canceledAt             DateTime?
  notes                  String?
  // Machine-readable map of env-var knob name -> string value implied by THIS
  // plan tier, overriding the provider's free-tier ProviderPlan.knobEnv when
  // present (see GET /api/subscriptions, which returns both the effective and
  // free-tier maps). Null means "no override — use the provider's free tier."
  knobEnv                Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([providerId])
  @@index([projectId])
  @@index([status, nextRenewalAt])
}

model ProviderProjectAllocation {
  id         String   @id @default(uuid())
  providerId String
  projectId  String
  percentage Float    @default(100) // Percentage of cost allocated to this project (0-100)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([providerId, projectId])
}
