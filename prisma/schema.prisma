generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Provider {
  id                    String                      @id @default(uuid())
  name                  String
  displayName           String
  type                  String                      @default("builtin")
  category              String?
  apiKey                String?
  config                Json?
  // Credential-bearing provider configuration (secondary secrets such as
  // Alpaca's API secret, Langfuse's secret key, xAI management keys, and
  // custom auth headers). Stored as a versioned AES-256-GCM JSON envelope and
  // never selected into client-facing DTOs.
  secretConfig          String?
  isActive              Boolean                     @default(true)
  // Monotonic revision for configuration that can change the evaluated alert
  // set without producing a newer UsageSnapshot (for example disable/re-enable
  // or threshold edits). Alert evidence is ordered by this value first.
  alertConfigGeneration Int                         @default(0)
  credits               Float                       @default(0)
  refreshIntervalMin    Int                         @default(60)
  groupId               String?
  label                 String?
  createdAt             DateTime                    @default(now())
  plan                  ProviderPlan?
  snapshots             UsageSnapshot[]
  snapshotRollups       UsageSnapshotDailyRollup[]
  alertNotifications    ProviderAlertNotification[]
  allocations           ProviderProjectAllocation[]
  subscriptions         Subscription[]
  externalBilling       ProviderExternalBilling[]
  externalBillingChargeCorrections ExternalBillingChargeCorrection[]
}

model ProviderPlan {
  id                  String    @id @default(uuid())
  providerId          String    @unique
  provider            Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  billingMode         String    @default("manual")
  fixedMonthlyCostUsd Float?
  monthlyBudgetUsd    Float?
  monthlyRequestLimit Int?
  lowBalanceUsd       Float?
  lowCredits          Float?
  renewalDate         DateTime?
  // Cadence at which renewalDate rolls forward once it passes (see
  // provider-alerts.ts effectiveRenewal + subscription-materializer's
  // renewal roll-forward). Independent of any Subscription row.
  billingInterval     String?   @default("monthly")
  mustKeepFunded      Boolean   @default(false)
  notes               String?
  // Machine-readable map of env-var knob name -> string value implied by this
  // provider's FREE tier (e.g. PROVIDER_QUOTA_* / PROVIDER_RATE_LIMIT_* / other
  // toggles a consuming app — Socratic.Trade — should apply at baseline). This
  // is the free-tier floor; a Subscription.knobEnv (paid tier) overrides it
  // when present. Null when no knob map has been defined yet.
  knobEnv             Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// Authoritative, read-only billing/account state synchronized from a
// provider's official API. These rows are deliberately separate from
// Subscription: this model only mirrors external plan/status/period data.
// Maintenance may conservatively adopt an exact authoritative recurring row
// into Subscription; the external identity then drives fixed-cost dedupe.
model ProviderExternalBilling {
  id                 String    @id @default(uuid())
  providerId         String
  provider           Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  source             String
  externalId         String
  // Explicit per-record authority to create/reconcile a paid recurring local
  // charge. Collection-level sync.authoritative only controls source pruning
  // and is deliberately never copied into this field.
  paidRecurringAuthoritative Boolean @default(false)
  kind               String
  // Human-readable paid product/service distinct from a tier or plan name.
  serviceName        String?
  planName           String?
  status             String?
  amountUsd          Float?
  currency           String?
  billingInterval    String?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextRenewalAt      DateTime?
  requestLimit       Float?
  requestLimitWindow String?
  spendLimitUsd      Float?
  spendLimitWindow   String?
  // Optional service-level usage/quota fields. These stay display-only and
  // never enter canonical provider budget math.
  usageQuantity      Float?
  remainingQuantity  Float?
  usageUnit          String?
  // canonical = authoritative total/standalone charge; component = child
  // breakdown of a canonical row; metadata = non-charge plan/quota record.
  rollupRole         String?
  // renewal | period_end | quota_reset | contract_end | report_through.
  // Prevents an observation cutoff or billing
  // period boundary from being presented as a guaranteed renewal.
  dateKind           String?
  syncedAt           DateTime
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([providerId, source, externalId])
  @@index([providerId, status])
}

model UsageSnapshot {
  id                       String    @id @default(uuid())
  providerId               String
  provider                 Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  fetchedAt                DateTime
  balance                  Float?
  totalCost                Float?
  // Portion of totalCost that the provider explicitly reports as fixed plan
  // or subscription cost. Budget math dedupes this against local
  // Subscription/ProviderPlan fixed charges instead of adding both.
  fixedCostIncludedUsd     Float?
  // Provider-reported window/provenance for totalCost. Canonical UTC-month
  // budget math excludes prior-month and incompatible billing-cycle totals.
  costWindowStart          DateTime?
  costWindowEnd            DateTime?
  costScope                String?
  // True when totalCost may contain fixed charges that the adapter cannot
  // classify exactly (for example an all-category invoice total).
  costIncludesUnknownFixed Boolean   @default(false)
  totalRequests            Int?
  credits                  Float?
  rawData                  Json?
  createdAt                DateTime  @default(now())
}

model UsageSnapshotDailyRollup {
  id                  String   @id @default(uuid())
  providerId          String
  provider            Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  day                 DateTime
  sampleCount         Int      @default(0)
  firstFetchedAt      DateTime
  lastFetchedAt       DateTime
  latestBalance       Float?
  latestTotalCost     Float?
  latestTotalRequests Int?
  latestCredits       Float?
  minBalance          Float?
  maxBalance          Float?
  maxTotalCost        Float?
  maxTotalRequests    Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([providerId, day])
  @@index([day])
}

model ExternalUsageEvent {
  id             String    @id @default(uuid())
  // Prisma's client-side @default(uuid()) generates the value in the app process
  // before the INSERT is sent, so it works the same way on SQLite as it does on
  // any other datasource - no database-side function (e.g. Postgres's
  // gen_random_uuid()/pgcrypto) is required. In practice this default is a
  // safety net that's essentially never exercised: the app always supplies an
  // explicit, content-derived idempotencyKey on insert (see
  // usage-telemetry.ts's deriveIdempotencyKey).
  idempotencyKey String    @unique @default(uuid())
  sourceApp      String
  environment    String?
  provider       String
  service        String?
  label          String?
  keyRef         String?
  billingMode    String    @default("estimated")
  metricType     String    @default("usage")
  quantity       Float?
  unit           String?
  costUsd        Float?
  requests       Int?
  credits        Float?
  limit          Float?
  limitWindow    String?
  tier           String?
  confidence     String    @default("estimated")
  windowStart    DateTime?
  windowEnd      DateTime?
  occurredAt     DateTime
  metadata       Json?
  createdAt      DateTime  @default(now())
  // First-class per-project attribution. Resolved at ingest from a
  // producer-supplied project name (OTEL_RESOURCE_ATTRIBUTES `project` for
  // Claude Code, or the top-level `project` field on the generic ingest
  // contract) by matching Project.name case-insensitively. Null when no
  // project was supplied or none matched; the raw producer string is kept in
  // metadata so a Project created later can be back-filled. SetNull so
  // deleting a Project never destroys usage history.
  projectId      String?
  project        Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([sourceApp, occurredAt])
  @@index([provider, occurredAt])
  @@index([keyRef, occurredAt])
  @@index([projectId, occurredAt])
}

model ExternalUsageEventDailyRollup {
  id                         String   @id @default(uuid())
  day                        DateTime
  groupKey                   String
  sourceApp                  String
  environment                String?
  provider                   String
  service                    String?
  label                      String?
  keyRef                     String?
  billingMode                String
  metricType                 String
  unit                       String?
  limitWindow                String?
  tier                       String?
  confidence                 String
  // Denormalized project dimension so per-project cost survives the raw-event
  // retention cutoff. Folded into groupKey (see data-retention.ts's
  // externalGroupKey) so rollup buckets never merge across projects.
  projectId                  String?
  eventCount                 Int      @default(0)
  // Nullable so rows created before cost-coverage tracking remain explicitly
  // unclassified instead of being misreported as authoritative zero-cost.
  pricedEventCount           Int?
  unpricedEventCount         Int?
  unclassifiedCostEventCount Int?
  totalCostUsd               Float    @default(0)
  totalRequests              Int      @default(0)
  totalQuantity              Float    @default(0)
  totalCredits               Float    @default(0)
  maxLimit                   Float?
  latestOccurredAt           DateTime
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([day, groupKey])
  @@index([sourceApp, day])
  @@index([provider, day])
  @@index([projectId, day])
}

model ExternalUsageEventTombstone {
  idempotencyKey String   @id
  occurredAt     DateTime
  prunedAt       DateTime @default(now())

  @@index([occurredAt])
  @@index([prunedAt])
}

// Durable checkpoint for converting OTLP cumulative Sum points into deltas.
// `seriesKey` hashes the metric name plus all resource/data-point attributes;
// raw high-cardinality attributes never need to be stored here. Checkpoint and
// ExternalUsageEvent writes happen in one transaction so an exporter retry or
// process restart cannot advance the counter without persisting its delta.
model OtlpMetricState {
  seriesKey         String   @id
  metricName        String
  startTimeUnixNano String?
  lastTimeUnixNano  String
  lastValue         Float
  lastPointKey      String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([updatedAt])
}

model ProviderAlertNotification {
  id                               String                         @id @default(uuid())
  providerId                       String
  provider                         Provider                       @relation(fields: [providerId], references: [id], onDelete: Cascade)
  stateKey                         String                         @unique
  alertCode                        String
  severity                         String
  providerName                     String
  providerDisplayName              String
  message                          String
  firstDetectedAt                  DateTime
  lastDetectedAt                   DateTime
  // Monotonic incident identity. Existing rows migrate as generation 1 and
  // new reopen events advance through an atomic compare-and-swap.
  incidentGeneration               Int                            @default(1)
  // Monotonic evidence guard. "clear" wins ties so a stale alert evaluator
  // cannot reopen an incident already resolved from equal/newer evidence.
  evidenceWatermarkAt              DateTime?
  // Source observation identity is ordered before the transition watermark.
  // For stale_snapshot this lets a newer snapshot outrank an older snapshot's
  // later stale deadline, while the unchanged snapshot can still transition
  // from fresh at fetchedAt to stale at its deterministic deadline.
  evidenceSourceAt                 DateTime?
  evidenceWatermarkState           String                         @default("legacy")
  // Provider alert-config revision that produced the durable evidence above.
  // Compared before source/transition time so a deliberate config transition
  // can supersede an unchanged snapshot or no-snapshot epoch sentinel.
  evidenceConfigGeneration         Int                            @default(0)
  // Existing rows predate generation-scoped PagerDuty dedup keys and must be
  // conservatively audited/resolved with the legacy key before local closure.
  pagerDutyAuditState              String                         @default("legacy_unknown")
  // Serializes activation/delivery against resolution for this incident. The
  // external channel calls remain outside SQLite transactions, so this durable
  // lease is the ordering boundary shared by competing workers.
  operationClaimToken              String?
  operationClaimGeneration         Int                            @default(0)
  operationClaimExpiresAt          DateTime?
  operationClaimIncidentGeneration Int?
  operationClaimConfigGeneration   Int?
  operationClaimEvidenceSourceAt   DateTime?
  operationClaimEvidenceAt         DateTime?
  operationClaimEvidenceState      String?
  lastSentAt                       DateTime?
  sendCount                        Int                            @default(0)
  resolvedAt                       DateTime?
  createdAt                        DateTime                       @default(now())
  updatedAt                        DateTime                       @updatedAt
  channelDeliveries                ProviderAlertChannelDelivery[]

  @@index([providerId, resolvedAt])
  @@index([lastSentAt])
}

// Per-destination delivery state. A notification can succeed on Slack while
// email/PagerDuty is temporarily down; keeping these outcomes separately stops
// the successful channel from being replayed on every maintenance tick. The
// channelKey is a one-way fingerprint of kind + destination, never a URL,
// routing key, or API key.
model ProviderAlertChannelDelivery {
  id                              String                    @id @default(uuid())
  notificationId                  String
  notification                    ProviderAlertNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channelKey                      String
  channelKind                     String
  lastAttemptAt                   DateTime?
  lastSucceededAt                 DateTime?
  // Durable per-send lease/generation. The claim is acquired with an atomic
  // conditional update before crossing the external trigger boundary.
  triggerClaimToken               String?
  triggerClaimGeneration          Int                       @default(0)
  triggerClaimExpiresAt           DateTime?
  triggerIncidentGeneration       Int?
  triggerOperationClaimGeneration Int?
  lastSucceededIncidentGeneration Int?
  pagerDutyDedupKey               String?
  attemptCount                    Int                       @default(0)
  successCount                    Int                       @default(0)
  resolveClaimToken               String?
  resolveClaimGeneration          Int                       @default(0)
  resolveClaimExpiresAt           DateTime?
  resolveIncidentGeneration       Int?
  resolveOperationClaimGeneration Int?
  lastResolveAttemptAt            DateTime?
  lastResolvedAt                  DateTime?
  lastResolvedIncidentGeneration  Int?
  resolveAttemptCount             Int                       @default(0)
  lastResolveError                String?
  lastError                       String?
  createdAt                       DateTime                  @default(now())
  updatedAt                       DateTime                  @updatedAt

  @@unique([notificationId, channelKey])
  @@index([notificationId, channelKind])
}

model Project {
  id               String   @id @default(uuid())
  name             String   @unique
  // Lowercased/trimmed `name`, set on every create/rename. DB-enforced
  // case-insensitive uniqueness: since project attribution resolves
  // producer-supplied names case-insensitively (project-resolver.ts), two
  // projects differing only in case would make that ambiguous. `name` alone is
  // only BINARY-unique in SQLite, so this closes the concurrent-create race an
  // app-level check can't. Nullable so the column is an additive migration on
  // existing rows (they read back via the lowercased-name fallback).
  nameKey          String?  @unique
  description      String?
  monthlyBudgetUsd Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  allocations    ProviderProjectAllocation[]
  externalEvents ExternalUsageEvent[]
  subscriptions  Subscription[]
}

// Recurring, fixed-fee cost (a SaaS plan, seat, add-on, etc.) attached to a
// provider and optionally attributed to a project. Source of truth for the
// schedule; the actual money flows through the usage pipeline via the
// subscription materializer (src/lib/subscription-materializer.ts), which
// emits one synthetic ExternalUsageEvent (metricType="subscription") per
// elapsed billing period. That keeps subscription cost in the SAME
// month-to-date sums, rollups, per-project attribution, and budgets as
// metered usage — no special-casing in budget-status.
model Subscription {
  id                     String    @id @default(uuid())
  providerId             String
  provider               Provider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  // Optional project attribution: materialized charges carry this projectId so
  // the fee lands in the right project budget. SetNull so deleting a Project
  // doesn't cascade-delete the subscription.
  projectId              String?
  project                Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  // Optional identity link to a read-only ProviderExternalBilling record.
  // Kept as scalar identity rather than a foreign key because authoritative
  // provider refreshes may remove/replace stale external rows; the local
  // subscription must survive that refresh. Budget math only dedupes a
  // provider-reported fixed fee when this exact identity is present and live.
  externalBillingSource  String?
  externalBillingId      String?
  // True only for subscriptions created by authoritative external-billing
  // maintenance. These are single-term schedules reconciled from fresh rows;
  // owner-created/linked rows remain false and are never overwritten.
  externalBillingManaged Boolean   @default(false)
  // Durable charge-shape guard used by auto-managed rows and by owner rows
  // explicitly linked to one exact eligible external source + ID. Never
  // inferred for an unlinked same-price row: price/cadence are not identity.
  externalAdoptionGuardKey String? @unique
  name                   String
  description            String?
  costUsd                Float
  currency               String    @default("USD")
  // weekly | monthly | quarterly | annual — combined with intervalCount for
  // arbitrary cadences (e.g. intervalCount=3 + interval="monthly").
  interval               String    @default("monthly")
  intervalCount          Int       @default(1)
  // Day-of-month the cycle renews (1-31); null derives the anchor from startDate.
  anchorDay              Int?
  startDate              DateTime
  currentPeriodStart     DateTime
  nextRenewalAt          DateTime
  // Materializer watermark: the periodStart of the most recent period already
  // emitted as a synthetic charge. Null until the first charge is generated.
  lastChargedPeriodStart DateTime?
  autoRenew              Boolean   @default(true)
  // active | paused | canceled | considering — only "active" subscriptions
  // generate charges. "considering" models a candidate paid tier that isn't
  // purchased yet, so its knobEnv can be compared against the free tier
  // without emitting phantom spend.
  status                 String    @default("active")
  canceledAt             DateTime?
  notes                  String?
  // Machine-readable map of env-var knob name -> string value implied by THIS
  // plan tier, overriding the provider's free-tier ProviderPlan.knobEnv when
  // present (see GET /api/subscriptions, which returns both the effective and
  // free-tier maps). Null means "no override — use the provider's free tier."
  knobEnv                Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([providerId])
  // One provider billing identity can prove/dedupe at most one materialized
  // local charge. SQLite permits multiple rows while either link field is NULL.
  @@unique([providerId, externalBillingSource, externalBillingId])
  @@index([projectId])
  @@index([status, nextRenewalAt])
}

// Immutable-period proof that a fresh authoritative provider observation
// corrected one exact already-materialized local subscription charge. Each
// corrected charge shape remains available for budget reconciliation and can
// settle a matching explicitly linked owner collision even after provider
// rollover, source staleness, or deletion of the managed Subscription row.
// Stale observations never create or update these rows.
model ExternalBillingChargeCorrection {
  id                    String       @id @default(uuid())
  providerId            String
  provider              Provider     @relation(fields: [providerId], references: [id], onDelete: Cascade)
  managedSubscriptionId String
  source                String
  externalId            String
  originalPeriodStart   DateTime
  originalPeriodEnd     DateTime
  originalAmountUsd     Float
  correctedPeriodStart  DateTime
  correctedPeriodEnd    DateTime
  correctedAmountUsd    Float
  correctedGuardKey     String
  observedAt            DateTime
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@unique([managedSubscriptionId, originalPeriodStart, correctedGuardKey])
  @@index([providerId, originalPeriodStart])
  @@index([providerId, correctedGuardKey])
}

model ProviderProjectAllocation {
  id         String   @id @default(uuid())
  providerId String
  projectId  String
  percentage Float    @default(100) // Percentage of cost allocated to this project (0-100)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  provider Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([providerId, projectId])
}
