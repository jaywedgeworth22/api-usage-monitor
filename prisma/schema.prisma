generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Provider {
  id                 String           @id @default(uuid())
  name               String
  displayName        String
  type               String           @default("builtin")
  apiKey             String?
  config             Json?
  isActive           Boolean          @default(true)
  credits            Float            @default(0)
  refreshIntervalMin Int              @default(60)
  groupId            String?
  label              String?
  createdAt          DateTime         @default(now())
  plan               ProviderPlan?
  snapshots          UsageSnapshot[]
}

model ProviderPlan {
  id                   String   @id @default(uuid())
  providerId           String   @unique
  provider             Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  billingMode          String   @default("manual")
  fixedMonthlyCostUsd  Float?
  monthlyBudgetUsd     Float?
  monthlyRequestLimit  Int?
  lowBalanceUsd        Float?
  lowCredits           Float?
  renewalDate          DateTime?
  mustKeepFunded       Boolean  @default(false)
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model UsageSnapshot {
  id            String   @id @default(uuid())
  providerId    String
  provider      Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  fetchedAt     DateTime
  balance       Float?
  totalCost     Float?
  totalRequests Int?
  credits       Float?
  rawData       Json?
  createdAt     DateTime @default(now())
}

model ExternalUsageEvent {
  id          String   @id @default(uuid())
  sourceApp   String
  environment String?
  provider    String
  service     String?
  label       String?
  keyRef      String?
  billingMode String   @default("estimated")
  metricType  String   @default("usage")
  quantity    Float?
  unit        String?
  costUsd     Float?
  requests    Int?
  credits     Float?
  limit       Float?
  limitWindow String?
  tier        String?
  confidence  String   @default("estimated")
  windowStart DateTime?
  windowEnd   DateTime?
  occurredAt  DateTime
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([sourceApp, occurredAt])
  @@index([provider, occurredAt])
  @@index([keyRef, occurredAt])
}
