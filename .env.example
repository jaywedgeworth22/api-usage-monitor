# Environment Variables
# Copy this file to .env and fill in your values

DATABASE_URL="file:./dev.db"

# Number of verified transaction-consistent snapshots retained beside an
# existing SQLite database before startup schema synchronization (1-10).
# SQLITE_PRE_MIGRATION_BACKUP_RETENTION="3"

# Encryption key for stored API keys (generate with: openssl rand -hex 32)
ENCRYPTION_KEY="change-me-to-a-random-64-char-hex-string"

# Cron secret to protect the fetch-all endpoint
CRON_SECRET="change-me-to-a-random-secret"

# Bearer token accepted by POST /api/ingest/usage for sibling app telemetry
USAGE_INGEST_TOKEN="change-me-to-a-random-secret"

# Optional: dedicated read-only token for GET /api/budget-status.
# Falls back to USAGE_INGEST_TOKEN when unset.
# USAGE_READ_TOKEN="change-me-to-another-random-secret"

# Shared password that gates access to the dashboard and its API routes (see /login)
DASHBOARD_PASSWORD="change-me-to-a-random-secret"

# Optional: enables the read-only Sentry Health dashboard card
# (GET /api/sentry-health). Absent by default -> card renders nothing.
# SENTRY_READ_TOKEN must be an org-auth-token (or internal integration token)
# with "project:read" / "event:read" scope. Never sent to the client.
# SENTRY_READ_TOKEN="change-me"
# SENTRY_ORG="jays-services"

# Optional: deliver provider budget/balance/stale alerts outside the dashboard.
# At least one channel must be set before outbound alert delivery sends anything.
# ALERT_SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
# ALERT_WEBHOOK_URL="https://example.com/internal/provider-alerts"
# ALERT_RESEND_API_KEY="re_..."
# ALERT_EMAIL_FROM="alerts@example.com"
# ALERT_EMAIL_TO="oncall@example.com"
# ALERT_PAGERDUTY_ROUTING_KEY="..."
# ALERT_MIN_SEVERITY="warning" # info | warning | critical
# ALERT_REMINDER_HOURS="24"
# Each channel HTTP attempt is time-bounded and retries only transient failures.
# ALERT_DELIVERY_TIMEOUT_MS="10000" # max 60000
# ALERT_DELIVERY_MAX_ATTEMPTS="3"   # includes first attempt; max 5
# ALERT_DELIVERY_RETRY_BASE_MS="250" # exponential waits, each capped at 5000ms

# Optional: raw-row retention before daily rollup + pruning.
# External events are never pruned from the current UTC month, even if this is lower.
# USAGE_SNAPSHOT_RAW_RETENTION_DAYS="45"
# EXTERNAL_USAGE_EVENT_RAW_RETENTION_DAYS="90"
# Legacy compatibility setting only. Rolled-up idempotency tombstones are now
# retained permanently so a late producer retry cannot be counted twice.
# EXTERNAL_USAGE_EVENT_TOMBSTONE_RETENTION_DAYS="180"

# Optional: hard ceiling for durable cumulative-OTLP series checkpoints.
# Checkpoints are not time-pruned because deleting one can replay a producer's
# full cumulative counter. New series fail with 503 once this safe bound is hit.
# OTLP_MAX_CUMULATIVE_SERIES="100000"

# Optional scheduler readiness tuning. One transient failed tick stays ready;
# repeated failures, a stalled tick, or a stale completed tick fail readiness.
# SCHEDULER_FAILURE_THRESHOLD="3"
# SCHEDULER_STALE_AFTER_MS="2700000"

# Optional: per-request timeout (ms) for poll-adapter HTTP calls (src/lib/adapters/helpers.ts's
# fetchJson). Defaults to 30000. Invalid/non-positive values fall back to the default.
# ADAPTER_HTTP_TIMEOUT_MS="30000"

# Optional: outer per-provider time budget (ms) for fetchAllDueProviders (src/lib/usage-recorder.ts).
# Bounds how long one provider's fetch can stall the sequential poll loop before it's counted as a
# failure and the loop moves on. Defaults to 90000. Invalid/non-positive values fall back to the default.
# ADAPTER_PROVIDER_TIMEOUT_MS="90000"

# Optional: continuous Litestream replication of /data/prod.db to an
# S3-compatible bucket (Cloudflare R2). The four of BUCKET/ENDPOINT/
# ACCESS_KEY_ID/SECRET_ACCESS_KEY must all be set to enable replication;
# REGION is optional (an empty region is fine for R2). See docs/litestream.md.
# With the four required unset -> no replication, no behavior change from today.
# LITESTREAM_S3_BUCKET="api-usage-monitor-backups"
# LITESTREAM_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
# LITESTREAM_S3_ACCESS_KEY_ID="change-me"
# LITESTREAM_S3_SECRET_ACCESS_KEY="change-me"
# LITESTREAM_S3_REGION="auto" # optional; defaults fine for R2
# LITESTREAM_REQUIRED="false" # set true only after a successful restore drill
