{
  "name": "api-usage-monitor",
  "homepage": "https://usage.jays.services",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "repair:claude-cost": "node scripts/repair-claude-cumulative-cost.mjs",
    "repair:anthropic-funding": "node scripts/repair-anthropic-funding.mjs",
    "import:billing-receipts": "node scripts/import-private-billing-receipts.mjs",
    "receipt-inbox:verify-lifecycle": "node scripts/verify-receipt-inbox-lifecycle.mjs",
    "receipt-inbox:deploy-auditor": "npm run receipt-inbox:verify-lifecycle && wrangler deploy --config workers/receipt-lifecycle-auditor/wrangler.jsonc",
    "receipt-inbox:deploy": "npm run receipt-inbox:deploy-auditor && wrangler deploy --config workers/receipt-inbox/wrangler.jsonc",
    "receipt-inbox:rules": "wrangler email routing rules list jays.services",
    "import:subscription-adjustments": "node scripts/import-manual-subscription-events.mjs",
    "audit:subscription-currency": "node scripts/audit-subscription-currency.mjs",
    "migrate:provider-secrets": "node scripts/migrate-provider-config-secrets.mjs",
    "audit:provider-duplicates": "node scripts/audit-provider-duplicates.mjs",
    "audit:subscription-links": "node scripts/audit-subscription-links.mjs",
    "ensure:subscription-link-index": "node scripts/ensure-subscription-link-unique-index.mjs",
    "test": "vitest run",
    "test:receipt-inbox-worker": "vitest run --config workers/receipt-inbox/vitest.config.mjs",
    "test:migrate-safe": "node scripts/test-migrate-safe-repro.mjs",
    "test:sqlite-backup": "node scripts/test-sqlite-pre-migration-backup.mjs",
    "test:startup-config": "node scripts/test-startup-config.mjs",
    "test:oracle-deploy": "node scripts/test-oracle-deploy-config.mjs",
    "test:apple-projects": "bash scripts/verify-apple-projects.sh",
    "verify": "npm run lint && npm run typecheck && npm test && npm run test:receipt-inbox-worker && npm run test:migrate-safe && npm run test:sqlite-backup && npm run test:startup-config && npm run test:oracle-deploy && npm run test:apple-projects && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "lucide-react": "^1.25.0",
    "next": "^15.5.19",
    "next-themes": "^0.4.6",
    "postal-mime": "^2.7.5",
    "protobufjs": "^8.7.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-is": "^19.0.0",
    "recharts": "^3.9.2",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@eslint/eslintrc": "^3.3.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.5.4",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "pg": "^8.22.0",
    "postcss": "^8.5.10",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "4.112.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "sharp": "0.35.3"
  }
}
