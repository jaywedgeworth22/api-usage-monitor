{
  "name": "api-usage-monitor",
  "homepage": "https://usage.jays.services",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.14.0 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:migrate-safe": "node scripts/test-migrate-safe-repro.mjs",
    "test:startup-config": "node scripts/test-startup-config.mjs",
    "verify": "npm run lint && npm run typecheck && npm test && npm run test:migrate-safe && npm run test:startup-config && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "next": "^15.1.0",
    "protobufjs": "^8.6.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "pg": "^8.22.0",
    "postcss": "^8.5.10",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
